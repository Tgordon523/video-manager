# Copy to .env and fill in the values below, then run: docker compose up --build

# --- Postgres (used by both the db service and the app) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=videos

# --- Google Drive via rclone ---
# Name of the rclone remote you created with `rclone config` (e.g. gdrive).
RCLONE_REMOTE=gdrive
# Folder INSIDE that remote to watch for .mp4 files (e.g. Videos/ToEdit).
# Leave blank to watch the remote's root.
RCLONE_DRIVE_PATH=

# Absolute path to the host directory that holds rclone.conf.
# macOS/Linux default is usually: $HOME/.config/rclone
# Replace /Users/you below with your actual home directory (no ~ shortcuts).
RCLONE_CONFIG_DIR=/Users/you/.config/rclone

# --- Scanner ---
# How often (seconds) to poll Drive for new files.
SCAN_INTERVAL_SECONDS=300
